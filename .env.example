# Slaytics — .env (minimal config)
# =================================================================
# Hanya 5 variabel di sini. Sisanya diatur lewat UI Settings (tersimpan di MongoDB).
#
# Pertama kali deploy: copy file ini jadi .env, isi yang wajib, lalu
# `docker compose up -d --build`. Setelah running, semua konfigurasi
# lain (OpenRouter, Telegram, Discord, Scheduler, Alerts) atur lewat
# UI di http://localhost → Settings.

# ─── MongoDB credentials (WAJIB ganti dari default) ───
# Database itu sendiri pakai credential ini, jadi gak bisa disimpan di DB.
MONGO_USERNAME=slaytics_admin
MONGO_PASSWORD=MyV3ryStr0ng_Pr0duct10n_P4ssw0rd!

# ─── JWT Secret (WAJIB ganti, generate random string panjang) ───
# Generate: openssl rand -hex 32
# Atau buka https://generate-secret.vercel.app/64 di browser
JWT_SECRET=a3f8b2c9d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1

# ─── Port mapping (boleh biarkan default) ───
API_PORT=3001
WEB_PORT=80

# =================================================================
# (OPSIONAL) Auto-migrate ke DB saat first boot
# =================================================================
# Variabel di bawah ini OPSIONAL. Kalau diisi, saat first boot
# akan otomatis di-copy ke MongoDB collection `app_settings`.
# Setelah itu kamu bisa edit lewat UI Settings dan setting di sini
# diabaikan. Cocok untuk one-time bootstrap supaya gak perlu isi UI.

OPENROUTER_API_KEY=your_key_here
TELEGRAM_BOT_TOKEN=1989853785:AAF9bxZ1gBhLm1UsDUu5eMXBH0ghx9hObDI
TELEGRAM_CHAT_ID=-588600801
# DISCORD_WEBHOOK_URL=
